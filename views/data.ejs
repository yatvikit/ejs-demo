<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <%
    if(arr.length==0)
    {%>
        <h1>No data found</h1> 
    <%}
    else
    {%>
        <table border="1">
            <tr>
                <th>Name</th>
                <th>Age</th>
                <th>City</th>
            </tr>
                    
            <% arr.forEach((obj)=>{ %>
                <tr>
                    <td><%= obj.name %></td>
                    <td><%= obj.age %></td>
                    <td><%= obj.city %></td>
                </tr>
            <% }) %>

        </table>

    <%}
    %>
</body>
</html>